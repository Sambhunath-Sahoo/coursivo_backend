spring.application.name=
server.port=${PORT:8080}

# DevTools Auto Restart on Code Change
spring.devtools.restart.enabled=
spring.devtools.livereload.enabled=

spring.datasource.url=
spring.datasource.username=
spring.datasource.password=

# JPA
spring.jpa.hibernate.ddl-auto=
spring.jpa.show-sql=

# JWT (do NOT commit real secrets; keep them in local application.properties or environment variables)
# security.jwt.secret should be a strong random string (32+ characters recommended for HS256)
security.jwt.secret=
security.jwt.expiration-minutes=
